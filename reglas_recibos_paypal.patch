@@ -0,0 +1,104 @@
+"""RegistroContable: mapea eventos financieros a asientos de partida doble.
+
+Patrón registry: (origen_tipo, tipo_apunte) → (cuenta_debe, cuenta_haber)
+basado en el Plan de Cuentas PCESFL 2013.
+"""
+from datetime import date
+from decimal import Decimal
+from typing import Optional
+from uuid import UUID
+
+from sqlalchemy.ext.asyncio import AsyncSession
+
+from ..models.tesoreria import ApunteCaja, TipoApunte, OrigenApunte
+from ..models.contabilidad import (
+    AsientoContable,
+    ApunteContable,
+    TipoAsientoContable,
+    EstadoAsientoContable,
+)
+from ..core.feature_flags import is_version_completa
+from .contabilidad_service import ContabilidadService
+
+# Mapeo: (origen, tipo_apunte) → (codigo_cuenta_debe, codigo_cuenta_haber)
+# Basado en PCESFL 2013 para entidades sin fines de lucro
+MAPA_CONTABLE = {
+    # Cobro de cuotas: banco a ingresos por cuotas
+    (OrigenApunte.CUOTA, TipoApunte.INGRESO): ("572", "721"),
+    # Devolución de cuota: reverso
+    (OrigenApunte.CUOTA, TipoApunte.GASTO): ("721", "572"),
+    # Cobro de donación: banco a ingresos por donaciones
+    (OrigenApunte.DONACION, TipoApunte.INGRESO): ("572", "730"),
+    # Cobro vía remesa: banco a clientes (se regulariza con cuota)
+    (OrigenApunte.REMESA, TipoApunte.INGRESO): ("572", "430"),
+    # Devolución de remesa
+    (OrigenApunte.REMESA, TipoApunte.GASTO): ("430", "572"),
+    # Cobro por pasarela de pago
+    (OrigenApunte.PAGO, TipoApunte.INGRESO): ("572", "721"),
+    # Gasto manual: gastos generales a banco
+    (None, TipoApunte.GASTO): ("629", "572"),
+    # Ingreso manual
+    (None, TipoApunte.INGRESO): ("572", "749"),
+}
+
+
+class RegistroContable:
+    """Genera automáticamente asientos contables a partir de apuntes de caja."""
+
+    def __init__(self, session: AsyncSession):
+        self.session = session
+        self.contabilidad = ContabilidadService(session)
+
+    async def generar_asiento_para_apunte(
+        self, apunte: ApunteCaja
+    ) -> Optional[AsientoContable]:
+        """Si la versión es COMPLETA, genera el asiento de partida doble."""
+        if not is_version_completa():
+            return None
+
+        # Resolver cuentas según el mapa
+        clave = (apunte.origen, apunte.tipo)
+        if clave not in MAPA_CONTABLE:
+            clave = (None, apunte.tipo)
+        if clave not in MAPA_CONTABLE:
+            return None
+
+        codigo_debe, codigo_haber = MAPA_CONTABLE[clave]
+
+        cuenta_debe = await self.contabilidad.obtener_cuenta_por_codigo(codigo_debe)
+        cuenta_haber = await self.contabilidad.obtener_cuenta_por_codigo(codigo_haber)
+
+        if not cuenta_debe or not cuenta_haber:
+            # Las cuentas del plan no están inicializadas aún — no se puede generar
+            return None
+
+        ejercicio = apunte.fecha.year
+        asiento = await self.contabilidad.crear_asiento(
+            ejercicio=ejercicio,
+            fecha=apunte.fecha,
+            glosa=apunte.concepto,
+            tipo_asiento=TipoAsientoContable.GESTION,
+        )
+
+        await self.contabilidad.añadir_apunte(
+            asiento_id=asiento.id,
+            cuenta_id=cuenta_debe.id,
+            debe=apunte.importe,
+            concepto=apunte.concepto,
+        )
+        await self.contabilidad.añadir_apunte(
+            asiento_id=asiento.id,
+            cuenta_id=cuenta_haber.id,
+            haber=apunte.importe,
+            concepto=apunte.concepto,
+        )
+
+        # Confirmar el asiento (siempre cuadrará al tener un solo par debe/haber)
+        asiento = await self.contabilidad.confirmar_asiento(asiento.id)
+
+        # Vincular el apunte al asiento generado
+        apunte.asiento_id = asiento.id
+        self.session.add(apunte)
+        await self.session.commit()
+
+        return asiento

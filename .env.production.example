# Plantilla de .env de STAGING/PRODUCCIÓN de SIGA. Solo marcadores, sin valores.
#
# Fuente única: se gestiona como GitHub Secret (ENV_STAGING / ENV_PRODUCTION) y
# el workflow lo vuelca en el servidor como .env.production (umask 077). El
# script de despliegue extrae las credenciales sensibles a Docker secret y hace
# `unset`, de modo que NO llegan al contenedor como variable de entorno plana.

# --- Identificación / dominio ---
APP_PREFIX=siga
APP_DOMAIN=REPLACE_ME            # p.ej. siga.staging.europalaica.org  |  siga.europalaica.org
TRAEFIK_CERTRESOLVER=letsencrypt

# --- Imágenes GHCR (el CI fija IMAGE_TAG al SHA; por defecto latest) ---
IMAGE_NAME_BACKEND=ghcr.io/pepeluimoreno/siga-backend
IMAGE_NAME_FRONTEND=ghcr.io/pepeluimoreno/siga-frontend
# IMAGE_TAG lo inyecta el workflow (DEPLOY_IMAGE_TAG). No fijar aquí salvo pin manual.

# --- Postgres / BD (db_password se materializa como Docker secret) ---
POSTGRES_USER=siga
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=siga
DB_HOST=db
DB_PORT=5432
DB_NAME=siga
DB_USER=siga

# --- Backend ---
JWT_SECRET=REPLACE_ME
APP_URL=https://REPLACE_ME

# --- Cuenta de sistema `superadmin` (break-glass) ---
# Se entrega como Docker secret (SUPERADMIN_PASSWORD_FILE=/run/secrets/superadmin_password).
SUPERADMIN_PASSWORD=

# --- SMTP (smtp_password → Docker secret) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_ENCRYPTION=tls

# --- Cifrado de datos sensibles (encryption_key → Docker secret) ---
ENCRYPTION_KEY=REPLACE_ME

# --- PayPal (paypal_client_secret → Docker secret) ---
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# --- Healthcheck del despliegue (DEBE devolver 200) ---
HEALTHCHECK_URL=https://REPLACE_ME/
HEALTHCHECK_RETRIES=20
HEALTHCHECK_INTERVAL=6

# --- GHCR (si el registro es privado) ---
GHCR_USER=pepeluimoreno
# GHCR_PAT lo inyecta el workflow desde el secret homónimo.

# --- Portainer (opcional) ---
# PORTAINER_WEBHOOK_URL=

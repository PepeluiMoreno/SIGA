# Plantilla de variables de entorno de SIGA para DESARROLLO (optiplex-790).
# Copia a .env y rellena los marcadores. NUNCA versiones el .env real.
#
# En desarrollo las credenciales pueden ir como env var (este .env). En
# staging/producción se entregan como Docker secret y el código las lee con el
# patrón <VAR>_FILE (ver Estándar de Ingeniería §4.5 y app/core/secrets.py).

# --- Identificación de la app (prefijo de contenedores y routers Traefik) ---
APP_PREFIX=siga
APP_DEV_DOMAIN=siga.optiplex-790

# --- Postgres (servicio db del compose) ---
POSTGRES_USER=siga
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=siga

# --- Backend ---
JWT_SECRET=REPLACE_ME
# URL pública usada en los enlaces de los emails
APP_URL=http://siga.optiplex-790

# --- Cuenta de sistema `superadmin` (break-glass) ---
# Si se define, bootstrap asegura el usuario `superadmin` (sin email) con rol
# SUPERADMIN. Los admin de trabajo se crean luego dentro de la app.
SUPERADMIN_PASSWORD=REPLACE_ME

# --- SMTP (opcional; si se deja vacío se usa la config guardada en BD) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_ENCRYPTION=tls

# --- Cifrado de datos sensibles en BD (opcional en dev; si falta se genera
#     una clave temporal y se avisa por log) ---
ENCRYPTION_KEY=

# --- PayPal (opcional; solo si se usa la pasarela) ---
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

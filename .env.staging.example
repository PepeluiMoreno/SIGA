# Plantilla de variables de entorno para SIGA.
# El .env real se inyecta en staging desde el secret SIGA_ENV_STAGING
# de GitHub Actions. Este archivo solo documenta qué variables hacen falta
# y NO contiene valores reales.

# --- Identificación de la app (se usa como prefijo de contenedores y routers) ---
APP_PREFIX=siga
APP_DOMAIN=siga.staging.europalaica.org

# --- Carril de staging (override extra) ---
# Activa docker-compose.staging.yml como 3.º -f: SIGA_ENV=staging + bind ro de
# los scripts de seeding/importacion (sembrar sin reconstruir la imagen).
# IMPRESCINDIBLE en staging; producción NO debe definirla (queda pura-imagen).
# Si se omitiera, el workflow la fija como salvaguarda, pero documéntala aquí.
COMPOSE_EXTRA_FILE=docker-compose.staging.yml

# --- Traefik (configuración del servidor anfitrión) ---
TRAEFIK_CERTRESOLVER=letsencrypt

# --- Postgres ---
POSTGRES_USER=siga
POSTGRES_PASSWORD=__SECRET__
POSTGRES_DB=siga

# --- Backend ---
JWT_SECRET=__SECRET__

# --- Cuenta de sistema `superadmin` (break-glass) ---
# bootstrap asegura el usuario `superadmin` (sin email, rol SUPERADMIN).
# En staging/prod se entrega como Docker secret (SUPERADMIN_PASSWORD_FILE).
SUPERADMIN_PASSWORD=__SECRET__

# Plantilla de variables de entorno para SIGA.
# El .env real se inyecta en staging desde el secret SIGA_ENV_STAGING
# de GitHub Actions. Este archivo solo documenta qué variables hacen falta
# y NO contiene valores reales.

# --- Identificación de la app (se usa como prefijo de contenedores y routers) ---
APP_PREFIX=siga
APP_DOMAIN=siga.staging.europalaica.org

# --- Traefik (configuración del servidor anfitrión) ---
TRAEFIK_CERTRESOLVER=letsencrypt

# --- Postgres ---
POSTGRES_USER=siga
POSTGRES_PASSWORD=__SECRET__
POSTGRES_DB=siga

# --- Backend ---
JWT_SECRET=__SECRET__

# --- Bootstrap (usuario admin inicial) ---
# Si están definidas y el usuario no existe, el script de bootstrap crea
# el admin inicial vinculado al rol SUPERADMIN. Si ya existe, no hace nada.
INITIAL_ADMIN_EMAIL=admin@siga.local
INITIAL_ADMIN_PASSWORD=__SECRET__
